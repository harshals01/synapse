# ── Vector Store (Qdrant Cloud — free tier) ───────────────────────────────────
QDRANT_URL=https://<your-cluster-id>.<region>.gcp.cloud.qdrant.io
QDRANT_API_KEY=<your-qdrant-cloud-api-key>
INDEX_NAME=data_store

# ── Hugging Face (Embedding + LLM) ────────────────────────────────────────────
HF_TOKEN=hf_<your-huggingface-read-token>

# Embedding model API URL (default uses all-MiniLM-L6-v2 via HF router)
# HF_EMBEDDING_API_URL=https://router.huggingface.co/hf-inference/models/sentence-transformers/all-MiniLM-L6-v2/pipeline/feature-extraction

# LLM model used for chat generation (any HF model on the serverless router)
HF_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# ── RAG Thresholds ────────────────────────────────────────────────────────────
LOW_CONFIDENCE_THRESHOLD=0.015
MAX_CONTEXT_DOCS=20
# Number of prior conversation turns sent to the LLM as chat history (default is 6)
CHAT_HISTORY_WINDOW=6

# ── Ingestion Tuning ──────────────────────────────────────────────────────────
# Number of text chunks sent to the HF API in a single batch request
INGEST_BATCH_SIZE=5
# Number of retry attempts on 429/503 responses from the HF API
MAX_EMBED_RETRIES=3

# ── Security ──────────────────────────────────────────────────────────────────
# Shared secret that clients must send as the X-API-Key request header.
# Generate a secure value with: openssl rand -hex 32
API_ACCESS_KEY=<your-secure-random-api-key>

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production, set this to your deployed frontend URL.
# Leave empty to default to http://localhost:5173 (Vite dev server).
ALLOWED_ORIGINS=<your-frontend-origin-url>
