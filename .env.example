# ── Vector Store (Qdrant Cloud — free tier) ───────────────────────────────────
QDRANT_URL=https://<your-cluster-id>.<region>.gcp.cloud.qdrant.io
QDRANT_API_KEY=<your-qdrant-cloud-api-key>
INDEX_NAME=data_store 

# ── Embedding (Hugging Face Serverless Inference) ─────────────────────────────
# Create a READ token at huggingface.co/settings/tokens
HF_TOKEN=hf_<your-huggingface-read-token>
# HF_EMBEDDING_API_URL=https://router.huggingface.co/hf-inference/models/sentence-transformers/all-MiniLM-L6-v2/pipeline/feature-extraction

# ── LLM (Gemini 2.0 Flash OR Hugging Face Serverless) ───────────────────────
# LLM_PROVIDER: "gemini" or "huggingface"
LLM_PROVIDER=gemini
# Create a key at aistudio.google.com/apikey  (format: AIza...)
GEMINI_API_KEY=AIza<your-google-ai-studio-api-key>
# If LLM_PROVIDER=huggingface, specify the model repository (e.g. Qwen/Qwen2.5-7B-Instruct)
HF_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# LLM_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent

# ── RAG Thresholds ────────────────────────────────────────────────────────────
LOW_CONFIDENCE_THRESHOLD=0.015
MAX_CONTEXT_DOCS=20

# ── Ingestion Tuning ──────────────────────────────────────────────────────────
# Number of text chunks sent to the HF API in a single batch request
INGEST_BATCH_SIZE=5
# Number of retry attempts on 429/503 responses from the HF API
MAX_EMBED_RETRIES=3
